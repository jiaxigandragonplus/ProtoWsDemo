{
    "server": {
        "name": "gate-server",
        "host": "0.0.0.0",
        "port": 8080
    },
    "database": {
        "mongo": {
            "uri": "mongodb://localhost:27017",
            "dbName": "game_db",
            "options": {
                "maxPoolSize": 10,
                "minPoolSize": 5
            }
        },
        "redis": {
            "host": "localhost",
            "port": 6379,
            "password": "",
            "db": 0
        }
    },
    "logger": {
        "level": "debug",
        "console": true,
        "file": {
            "enabled": true,
            "path": "./logs",
            "maxSize": 10485760,
            "maxFiles": 10
        }
    },
    "discovery": {
        "enabled": true,
        "serviceName": "gate-server",
        "heartbeatInterval": 5000,
        "discoveryInterval": 10000
    }
}